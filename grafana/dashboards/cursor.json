{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "title": "Cursor — Agent Activity",
  "uid": "cursor-overview",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "tags": ["cursor", "otel", "gen-ai"],
  "description": "Cursor telemetry: local activity (all plans) + monthly API usage (premium fast requests, Free plan shows 0) + agent turns (cursor-otel MCP server).",
  "templating": {"list": []},
  "panels": [

    {
      "id": 100,
      "type": "row",
      "title": "Local Activity (all plans — from ai-tracking DB)",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Agent requests (all-time)",
      "description": "Unique requestIds in Cursor's local ai-tracking DB. Each represents one agent session request.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [{"expr": "cursor_local_requests", "instant": true, "refId": "A"}]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "AI-generated files (all-time)",
      "description": "Total code files created or modified by Cursor agent, tracked locally.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [{"expr": "sum(cursor_local_code_files)", "instant": true, "refId": "A"}]
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Lines added by agent (all-time)",
      "description": "Total lines of code added across all Cursor agent sessions.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [{"expr": "cursor_local_lines_added", "instant": true, "refId": "A"}]
    },
    {
      "id": 104,
      "type": "stat",
      "title": "Avg files / request",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "targets": [{"expr": "sum(cursor_local_code_files) / scalar(sum(cursor_local_requests))", "instant": true, "refId": "A"}]
    },
    {
      "id": 105,
      "type": "timeseries",
      "title": "Agent requests over time",
      "description": "Running total of unique agent requests in local DB — slope indicates frequency of use.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 6},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [{"expr": "cursor_local_requests", "legendFormat": "total requests", "refId": "A"}]
    },
    {
      "id": 106,
      "type": "piechart",
      "title": "AI-generated files by type",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 6},
      "options": {"pieType": "donut", "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}},
      "targets": [{"expr": "cursor_local_code_files", "legendFormat": "{{file_ext}}", "refId": "A", "instant": true}]
    },
    {
      "id": 107,
      "type": "timeseries",
      "title": "Lines added by agent over time",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 15},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 10}}},
      "targets": [{"expr": "cursor_local_lines_added", "legendFormat": "lines added", "refId": "A"}]
    },

    {
      "id": 200,
      "type": "row",
      "title": "Premium Fast Requests (Free plan: always 0 — upgrade for data here)",
      "collapsed": true,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "panels": [
        {
          "id": 21,
          "type": "stat",
          "title": "Requests this month",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 5, "w": 6, "x": 0, "y": 25},
          "fieldConfig": {"defaults": {"unit": "short"}},
          "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
          "targets": [{"expr": "sum(cursor_usage_requests)", "instant": true, "refId": "A"}]
        },
        {
          "id": 22,
          "type": "stat",
          "title": "Tokens this month",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 5, "w": 6, "x": 6, "y": 25},
          "fieldConfig": {"defaults": {"unit": "short"}},
          "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
          "targets": [{"expr": "sum(cursor_usage_tokens)", "instant": true, "refId": "A"}]
        },
        {
          "id": 23,
          "type": "stat",
          "title": "Avg tokens / request",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 5, "w": 6, "x": 12, "y": 25},
          "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
          "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
          "targets": [{"expr": "sum(cursor_usage_tokens) / sum(cursor_usage_requests)", "instant": true, "refId": "A"}]
        },
        {
          "id": 25,
          "type": "timeseries",
          "title": "Requests this month — running total by model",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 9, "w": 12, "x": 0, "y": 30},
          "fieldConfig": {"defaults": {"unit": "short"}},
          "targets": [{"expr": "cursor_usage_requests", "legendFormat": "{{model}}", "refId": "A"}]
        },
        {
          "id": 26,
          "type": "timeseries",
          "title": "Tokens this month — running total by model",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 9, "w": 12, "x": 12, "y": 30},
          "fieldConfig": {"defaults": {"unit": "short"}},
          "targets": [{"expr": "cursor_usage_tokens", "legendFormat": "{{model}}", "refId": "A"}]
        },
        {
          "id": 27,
          "type": "piechart",
          "title": "Requests by model (this month)",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 9, "w": 12, "x": 0, "y": 39},
          "options": {"pieType": "donut", "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}},
          "targets": [{"expr": "cursor_usage_requests", "legendFormat": "{{model}}", "refId": "A", "instant": true}]
        },
        {
          "id": 28,
          "type": "piechart",
          "title": "Tokens by model (this month)",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 9, "w": 12, "x": 12, "y": 39},
          "options": {"pieType": "donut", "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]}},
          "targets": [{"expr": "cursor_usage_tokens", "legendFormat": "{{model}}", "refId": "A", "instant": true}]
        }
      ]
    },

    {
      "id": 300,
      "type": "row",
      "title": "Agent Turns (cursor-otel MCP server — requires setup)",
      "collapsed": true,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "panels": [
        {
          "id": 1,
          "type": "stat",
          "title": "Agent turns (selected range)",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 5, "w": 8, "x": 0, "y": 26},
          "fieldConfig": {"defaults": {"unit": "short"}},
          "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
          "targets": [{"expr": "sum(increase(cursor_calls_total[$__range]))", "instant": true, "refId": "A"}]
        },
        {
          "id": 3,
          "type": "stat",
          "title": "Error rate",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 5, "w": 8, "x": 8, "y": 26},
          "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.05}, {"color": "red", "value": 0.15}]}}},
          "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
          "targets": [{"expr": "sum(increase(cursor_calls_total{status_code=\"STATUS_CODE_ERROR\"}[$__range])) / sum(increase(cursor_calls_total[$__range]))", "instant": true, "refId": "A"}]
        },
        {
          "id": 31,
          "type": "stat",
          "title": "Median turn duration",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 5, "w": 8, "x": 16, "y": 26},
          "fieldConfig": {"defaults": {"unit": "ms"}},
          "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
          "targets": [{"expr": "histogram_quantile(0.50, sum by (le) (rate(cursor_duration_milliseconds_bucket[$__rate_interval])))", "instant": true, "refId": "A"}]
        },
        {
          "id": 5,
          "type": "timeseries",
          "title": "Agent request rate (turns/min)",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 9, "w": 12, "x": 0, "y": 31},
          "fieldConfig": {"defaults": {"unit": "short"}},
          "targets": [{"expr": "sum by (gen_ai_request_model) (rate(cursor_calls_total[$__rate_interval])) * 60", "legendFormat": "{{gen_ai_request_model}}", "refId": "A"}]
        },
        {
          "id": 6,
          "type": "timeseries",
          "title": "Agent turn duration (p50 / p95)",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "gridPos": {"h": 9, "w": 12, "x": 12, "y": 31},
          "fieldConfig": {"defaults": {"unit": "ms"}},
          "targets": [
            {"expr": "histogram_quantile(0.50, sum by (le, gen_ai_request_model) (rate(cursor_duration_milliseconds_bucket[$__rate_interval])))", "legendFormat": "p50 {{gen_ai_request_model}}", "refId": "A"},
            {"expr": "histogram_quantile(0.95, sum by (le, gen_ai_request_model) (rate(cursor_duration_milliseconds_bucket[$__rate_interval])))", "legendFormat": "p95 {{gen_ai_request_model}}", "refId": "B"}
          ]
        },
        {
          "id": 9,
          "type": "logs",
          "title": "Cursor agent logs (Loki)",
          "datasource": {"type": "loki", "uid": "loki"},
          "gridPos": {"h": 12, "w": 24, "x": 0, "y": 40},
          "options": {"showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true},
          "targets": [{"expr": "{service_name=~\"cursor.*\"}", "refId": "A"}]
        }
      ]
    }

  ]
}
