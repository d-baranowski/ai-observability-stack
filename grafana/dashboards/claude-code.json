{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "title": "Claude Code — Cost & Usage",
  "uid": "claude-code-overview",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "tags": ["claude-code", "otel"],
  "templating": {
    "list": [
      {
        "name": "user",
        "label": "User",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(claude_code_cost_usage_USD_total, user_email)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(claude_code_token_usage_tokens_total, model)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total cost (selected range)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 5},
            {"color": "red", "value": 25}
          ]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [{
        "expr": "sum(increase(claude_code_cost_usage_USD_total{user_email=~\"$user\"}[$__range]))",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active time",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
